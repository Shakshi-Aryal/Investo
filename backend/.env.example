# Investo Backend — copy to .env (never commit .env to Git)

# ── Core Django ───────────────────────────────────────────────
SECRET_KEY=generate-a-long-random-string-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-backend.onrender.com
TIME_ZONE=Asia/Kathmandu

# ── PostgreSQL (Render: use Internal Database URL fields) ─────
DATABASE_NAME=investo_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your-db-password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# ── Frontend (CORS + email verification links) ────────────────
FRONTEND_URL=https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
# CORS_ALLOW_ALL_ORIGINS=False

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=1

# ── Google OAuth (optional) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (verification, password reset, optional purchase alerts) ─
EMAIL_PROVIDER=smtp
DEFAULT_FROM_EMAIL=Investo <investo000111@gmail.com>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=investo000111@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_ON_TRANSACTIONS=False

# ── Redis (Render Redis / Upstash — required for WebSockets + Celery) ─
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# ── MongoDB (optional activity logs) ──────────────────────────
MONGO_URI=mongodb://localhost:27017/investo_logs

# ── Static files (Render collectstatic) ───────────────────────
STATIC_ROOT=/opt/render/project/src/backend/staticfiles

# ── NEPSE market simulation ───────────────────────────────────
# nepse_hours = Mon–Fri 11:00–15:00 Asia/Kathmandu only
# always_open = 24/7 ticks (dev/demo only)
MARKET_SIMULATION_MODE=nepse_hours
