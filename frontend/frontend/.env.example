# Investo Frontend — copy to .env.local (Vite; never commit secrets)

# REST API origin (no trailing slash) — Render backend URL in production
VITE_API_URL=https://your-backend.onrender.com

# WebSocket origin (defaults to VITE_API_URL with ws:// scheme)
# VITE_WS_URL=wss://your-backend.onrender.com

# Google OAuth client ID (must match backend GOOGLE_CLIENT_ID)
# VITE_GOOGLE_CLIENT_ID=
